{
  "database": {
    "rules": "database.rules.json"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "database.rules.json",
      "**/.*",
      "**/node_modules/**",
      "server-rapido.js",
      "CLAUDE.md",
      "index.backup-*",
      "backup_dados.json",
      "maintenance-preview.html",
      "preview-*.html"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
